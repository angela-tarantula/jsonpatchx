{
  "components": {
    "schemas": {
      "ConfigId": {
        "enum": [
          "service"
        ],
        "title": "ConfigId",
        "type": "string"
      },
      "GenericIncrementEachOp_JSONPathSelectorV2_": {
        "additionalProperties": true,
        "description": "Increment every numeric match produced by a generic JSONSelector backend.",
        "properties": {
          "op": {
            "const": "generic_increment_each",
            "description": "The operation to perform.",
            "title": "Op",
            "type": "string"
          },
          "path": {
            "description": "JSON selector string (custom backend syntax)",
            "format": "x-json-selector",
            "title": "Path",
            "type": "string",
            "x-selector-type-schema": {
              "type": "number"
            }
          },
          "value": {
            "gt": 0,
            "title": "Value",
            "type": "number"
          }
        },
        "required": [
          "op",
          "path",
          "value"
        ],
        "title": "Increment selected numbers",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ServiceConfigPatchOperation": {
        "description": "Discriminated union of patch operations for ServiceConfig.",
        "discriminator": {
          "mapping": {
            "generic_increment_each": "#/components/schemas/GenericIncrementEachOp_JSONPathSelectorV2_",
            "set_selected_flags": "#/components/schemas/SetSelectedFlagsOp",
            "toggle_selected_flags": "#/components/schemas/ToggleSelectedFlagsOp"
          },
          "propertyName": "op"
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/GenericIncrementEachOp_JSONPathSelectorV2_"
          },
          {
            "$ref": "#/components/schemas/SetSelectedFlagsOp"
          },
          {
            "$ref": "#/components/schemas/ToggleSelectedFlagsOp"
          }
        ],
        "title": "ServiceConfig Patch Operation"
      },
      "ServiceConfigPatchRequest": {
        "description": "Array of patch operations for ServiceConfig.",
        "items": {
          "$ref": "#/components/schemas/ServiceConfigPatchOperation"
        },
        "title": "ServiceConfig Patch Request",
        "type": "array"
      },
      "SetSelectedFlagsOp": {
        "additionalProperties": true,
        "description": "Set every boolean matched by a custom selector backend to the same value.",
        "properties": {
          "op": {
            "const": "set_selected_flags",
            "description": "The operation to perform.",
            "title": "Op",
            "type": "string"
          },
          "path": {
            "description": "JSON selector string (custom backend syntax)",
            "format": "x-json-selector",
            "title": "Path",
            "type": "string",
            "x-selector-type-schema": {
              "type": "boolean"
            }
          },
          "value": {
            "title": "Value",
            "type": "boolean"
          }
        },
        "required": [
          "op",
          "path",
          "value"
        ],
        "title": "Set selected flags",
        "type": "object"
      },
      "ToggleSelectedFlagsOp": {
        "additionalProperties": true,
        "description": "Toggle every boolean matched by JsonPatchX's built-in JSONPath selector backend.",
        "properties": {
          "op": {
            "const": "toggle_selected_flags",
            "description": "The operation to perform.",
            "title": "Op",
            "type": "string"
          },
          "path": {
            "description": "JSONPath (RFC 9535) string",
            "format": "json-path",
            "title": "Path",
            "type": "string",
            "x-selector-type-schema": {
              "type": "boolean"
            }
          }
        },
        "required": [
          "op",
          "path"
        ],
        "title": "Toggle selected flags",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Demo 8: Config patching with JSONSelector operations using the built-in JSONPath backend, a generic selector-backend parameter, and a custom selector backend implementation.",
    "title": "JSONSelector-powered config patches",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/configs/{config_id}": {
      "get": {
        "description": "Fetch a service config by id.",
        "operationId": "get_config_endpoint_configs__config_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "config_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/ConfigId"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response Get Config Endpoint Configs  Config Id  Get"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get a service config",
        "tags": [
          "configs"
        ]
      },
      "patch": {
        "description": "Apply JSONSelector-based custom operations to a service config.",
        "operationId": "patch_config_configs__config_id__patch",
        "parameters": [
          {
            "in": "path",
            "name": "config_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/ConfigId"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "examples": {
                "jsonpath-default": {
                  "summary": "toggle every feature flag via the built-in JSONPath backend",
                  "value": [
                    {
                      "op": "toggle_selected_flags",
                      "path": "$.features.*"
                    }
                  ]
                },
                "selector-sweep": {
                  "summary": "increment every numeric limit and enable every feature flag",
                  "value": [
                    {
                      "op": "generic_increment_each",
                      "path": "$.limits.*",
                      "value": 5
                    },
                    {
                      "op": "set_selected_flags",
                      "path": "features.*",
                      "value": true
                    }
                  ]
                }
              },
              "schema": {
                "$ref": "#/components/schemas/ServiceConfigPatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response Patch Config Configs  Config Id  Patch"
                }
              }
            },
            "description": "Successful Response"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "detail": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "properties": {
                            "cause_type": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "index": {
                              "type": "integer"
                            },
                            "message": {
                              "type": "string"
                            },
                            "op": {
                              "type": "object"
                            }
                          },
                          "required": [
                            "index",
                            "op",
                            "message"
                          ],
                          "type": "object"
                        }
                      ]
                    }
                  },
                  "required": [
                    "detail"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Patch cannot be applied to current resource state"
          },
          "415": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "detail": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "properties": {
                            "cause_type": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "index": {
                              "type": "integer"
                            },
                            "message": {
                              "type": "string"
                            },
                            "op": {
                              "type": "object"
                            }
                          },
                          "required": [
                            "index",
                            "op",
                            "message"
                          ],
                          "type": "object"
                        }
                      ]
                    }
                  },
                  "required": [
                    "detail"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Unsupported Media Type"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "properties": {
                        "detail": {
                          "oneOf": [
                            {
                              "type": "string"
                            },
                            {
                              "properties": {
                                "cause_type": {
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "index": {
                                  "type": "integer"
                                },
                                "message": {
                                  "type": "string"
                                },
                                "op": {
                                  "type": "object"
                                }
                              },
                              "required": [
                                "index",
                                "op",
                                "message"
                              ],
                              "type": "object"
                            }
                          ]
                        }
                      },
                      "required": [
                        "detail"
                      ],
                      "type": "object"
                    },
                    {
                      "$ref": "#/components/schemas/HTTPValidationError"
                    }
                  ]
                }
              }
            },
            "description": "Request validation or patch document validation error"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "detail": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "properties": {
                            "cause_type": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "index": {
                              "type": "integer"
                            },
                            "message": {
                              "type": "string"
                            },
                            "op": {
                              "type": "object"
                            }
                          },
                          "required": [
                            "index",

                          ],
                          "type": "object"
                        }
                      ]
                    }
                  },
                  "required": [
                    "detail"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Patch execution error"
          }
        },
        "summary": "Patch a service config with selectors",
        "tags": [
          "configs"
        ]
      }
    }
  }

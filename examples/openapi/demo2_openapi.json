  "info": {
    "description": "Demo 2: Custom registries per model (players vs guilds) using `JsonPatchFor[Model, CustomRegistry]`.",
    "title": "Player and guild progression",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/guilds/{guild_id}": {
      "get": {
        "description": "Fetch a guild by id.",
        "operationId": "get_guild_endpoint_guilds__guild_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "guild_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/GuildId"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guild"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get a guild",
        "tags": [
          "guilds"
        ]
      },
      "patch": {
        "description": "Apply custom ops to a Guild model.",
        "operationId": "patch_guild_guilds__guild_id__patch",
        "parameters": [
          {
            "in": "path",
            "name": "guild_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/GuildId"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "examples": {
                "cozy-welcome": {
                  "summary": "Trim members to cap and add a badge",
                  "value": [
                    {
                      "max_path": "/max_members",
                      "op": "enforce_max_len",
                      "path": "/members"
                    },
                    {
                      "op": "append",
                      "path": "/badges",
                      "value": "candle-lit"
                    }
                  ]
                },
                "owl-parade": {
                  "summary": "Add badge and raise cap",
                  "value": [
                    {
                      "op": "append",
                      "path": "/badges",
                      "value": "raid-ready"
                    },
                    {
                      "op": "increment",
                      "path": "/max_members",
                      "value": 5
                    }
                  ]
                },
                "snug-fit": {
                  "summary": "Add a member, then trim to max size",
                  "value": [
                    {
                      "op": "append",
                      "path": "/members",
                      "value": "Nova"
                    },
                    {
                      "max_path": "/max_members",
                      "op": "enforce_max_len",
                      "path": "/members"
                    }
                  ]
                }
              },
              "schema": {
                "$ref": "#/components/schemas/GuildPatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guild"
                }
              }
            },
            "description": "Successful Response"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "detail": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "properties": {
                            "cause_type": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "index": {
                              "type": "integer"
                            },
                            "message": {
                              "type": "string"
                            },
                            "op": {
                              "type": "object"
                            }
                          },
                          "required": [
                            "index",
                            "op",
                            "message"
                          ],
                          "type": "object"
                        }
                      ]
                    }
                  },
                  "required": [

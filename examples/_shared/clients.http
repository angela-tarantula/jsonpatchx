# VSCode REST client / HTTPie snippets for the demo apps.

# Standard typed model
GET http://localhost:8000/users/1

###
PATCH http://localhost:8000/users/1
Content-Type: application/json-patch+json

[
  {"op": "replace", "path": "/name", "value": "Morgan"}
]

###
# Standard untyped doc
GET http://localhost:8000/configs/site

###
PATCH http://localhost:8000/configs/site
Content-Type: application/json-patch+json

[
  {"op": "add", "path": "/features/list/0", "value": "first"}
]

###
# Custom ops
GET http://localhost:8001/configs/limits

###
PATCH http://localhost:8001/configs/limits
Content-Type: application/json-patch+json

[
  {"op": "increment", "path": "/max_users", "value": 2}
]

###
# Custom pointer backend
PATCH http://localhost:8002/configs/site
Content-Type: application/json-patch+json

[
  {"op": "replace", "path": "features.chat", "value": false}
]

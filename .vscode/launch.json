{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current submodule",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "${relativeFileDirname}.${fileBasenameNoExtension}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}

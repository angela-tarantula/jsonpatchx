          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "properties": {
                        "detail": {
                          "oneOf": [
                            {
                              "type": "string"
                            },
                            {
                              "properties": {
                                "cause_type": {
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "index": {
                                  "type": "integer"
                                },
                                "message": {
                                  "type": "string"
                                },
                                "op": {
                                  "type": "object"
                                }
                              },
                              "required": [
                                "index",
                                "op",
                                "message"
                              ],
                              "type": "object"
                            }
                          ]
                        }
                      },
                      "required": [
                        "detail"
                      ],
                      "type": "object"
                    },
                    {
                      "$ref": "#/components/schemas/HTTPValidationError"
                    }
                  ]
                }
              }
            },
            "description": "Request validation or patch document validation error"
          },
          "500": {
            "content": {

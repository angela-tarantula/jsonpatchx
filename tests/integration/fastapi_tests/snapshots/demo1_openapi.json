                            "message"
                          ],
                          "type": "object"
                        }
                      ]
                    }
                  },
                  "required": [
                    "detail"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Patch execution error"
          }
        },
        "summary": "Patch a customer",
        "tags": [

                        {
                          "properties": {
                            "cause_type": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "index": {
                              "type": "integer"
                            },
                            "message": {
                              "type": "string"
                            },
                            "op": {
                              "type": "object"
                            }
                          },
                          "required": [
                            "index",
                            "op",
                            "message"
                          ],
